import {
  "moonbitlang/ulex-runtime/lexbuf",
  "moonbitlang/core/int",
}

warnings = "-unused_value-unresolved_type_variable"

options(
  "pre-build": [
    {
      "command": "node $mod_dir/boot/snapshot/moonlex.cjs $input -o $output",
      "input": "named_regexes.mbtx",
      "output": "named_regexes.mbt",
    },
  ],
)
